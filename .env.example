# qBittorrent Service — Environment Variables
# Copy this file to .env and fill in values

# ── Timezone ──────────────────────────────────────────────────
TZ=America/Los_Angeles

# ── WebUI Credentials ────────────────────────────────────────
# Pre-configured on boot via custom-cont-init.d/configure-webui-auth.sh
WEBUI_USERNAME=admin
WEBUI_PASSWORD=admin
